# ─────────────────────────────────────────────────────────────
# Supabase (backend — service_role, ignora RLS, somente server-side)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Aceita SUPABASE_KEY ou SUPABASE_SERVICE_KEY (use a service_role key).
SUPABASE_KEY=

# ─────────────────────────────────────────────────────────────
# DataJud (CNJ) — chave PÚBLICA compartilhada, pode rotacionar.
# Fonte: https://datajud-wiki.cnj.jus.br/api-publica/acesso
# Se vazio, o código usa a chave pública conhecida como fallback.
# ─────────────────────────────────────────────────────────────
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# ─────────────────────────────────────────────────────────────
# Execução
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
SYNC_BATCH_SIZE=50
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────
# Docker (deploy no servidor) — porta/bind do dashboard
# Bind padrão 127.0.0.1 (acessível via túnel SSH ou reverse proxy; a app NÃO tem auth).
# Ajuste WEB_PORT para uma porta livre no servidor (não conflitar com n8n etc.).
# ─────────────────────────────────────────────────────────────
WEB_BIND=127.0.0.1
WEB_PORT=8090
